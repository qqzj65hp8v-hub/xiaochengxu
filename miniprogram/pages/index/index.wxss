/* index.wxss */

page {
  height: 100%;
  background-color: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #4A90D9;
  color: #fff;
}

.week-selector {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.week-name {
  font-size: 28rpx;
  font-weight: 500;
}

.week-arrow {
  font-size: 20rpx;
  margin-left: 10rpx;
}

.add-btn {
  padding: 10rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 28rpx;
}

.loading-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.timetable {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.timetable-header {
  display: flex;
  background-color: #f8f8f8;
  border-bottom: 1rpx solid #eee;
}

.header-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.time-header {
  flex: 0 0 100rpx;
  color: #999;
}

.timetable-body {
  flex: 1;
  height: 0;
}

.timetable-row {
  display: flex;
  min-height: 100rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.time-cell {
  flex: 0 0 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #fafafa;
  border-right: 1rpx solid #eee;
  padding: 10rpx;
}

.slot-label {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.slot-time {
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
}

.day-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100rpx;
  border-right: 1rpx solid #f0f0f0;
  position: relative;
}

.day-cell:last-child {
  border-right: none;
}

.course-card {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 4rpx;
  bottom: 4rpx;
  border-radius: 8rpx;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
  overflow: hidden;
}

.course-name {
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.course-location {
  font-size: 18rpx;
  margin-top: 4rpx;
  opacity: 0.9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}
