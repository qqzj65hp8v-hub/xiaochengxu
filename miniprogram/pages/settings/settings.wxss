/* pages/settings/settings.wxss */

page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
}

.stats-card {
  display: flex;
  background-color: #4A90D9;
  border-radius: 16rpx;
  padding: 40rpx 0;
  margin-bottom: 30rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.stats-value {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.settings-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item.danger .item-text {
  color: #F56C6C;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-icon {
  font-size: 36rpx;
}

.item-text {
  font-size: 30rpx;
  color: #333;
}

.item-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.version {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
}
